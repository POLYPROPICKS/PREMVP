SUPABASE_SERVICE_ROLE_KEY=

# ---------------------------------------------------------------------------
# Payment / Whop v0.1
# ---------------------------------------------------------------------------
PAYMENT_PROVIDER=whop
# Set to true only after SQL schema applied and checkout route is deployed.
CHECKOUT_ENABLED=false
NEXT_PUBLIC_APP_URL=https://polypropicks.com

# WHOP_API_KEY must be a fresh production key.
# Do NOT use any screenshot-exposed proof/test key here.
WHOP_API_KEY=

# Webhook signing secret — copy from Whop Dashboard > Webhooks > your endpoint.
WHOP_WEBHOOK_SECRET=

# Public business/product identifiers (not secret).
WHOP_COMPANY_ID=biz_6LaDCFvRiwJRsa
WHOP_PRODUCT_ID=prod_XLfbDp2YFkaZJ

# Existing dashboard plan id — optional.
# Checkout v0.1 uses proven inline plan config path unless later confirmed otherwise.
WHOP_PLAN_ID_7DAY=plan_iZXc2rkE8UIxy

# Signed session cookie secret — generate a strong random string before enabling.
PPP_SESSION_SECRET=

# Do NOT commit real secret values to version control.