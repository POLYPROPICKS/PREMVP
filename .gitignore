# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
node_modules/
.next/
.env
.env.local
*.log
.claude/ 
debug-evidence-check.json
debug-v2.json

# Railway env snapshots — never commit, contain live secrets
railway-config*.json
railway-env*.json
landing-check.json 
*.json
# Founder status snapshots are runtime artifacts (MODE A producer output)
reports/morning/latest_founder_status_snapshot.md
# Liquidity funnel reports are runtime artifacts; keep the dir via .gitkeep only
reports/liquidity_pool/*.md
!reports/liquidity_pool/.gitkeep
normalize-dump.txt
recon-css.txt
recon-full.txt

# Visual Matrix Runner generated output (screenshots, contact sheets)
visual-runs/

# ── PolyProPicks portrait source / preview artifacts ─────────────────────────
# Preview harness docs (static HTML, not part of runtime)
/docs/ui-previews/market-source-portraits/
/docs/ui-previews/shark-flow-portrait-placement/

# One-off normalization script (not part of runtime)
/scripts/normalize-market-source-portraits.mjs

# Raw portrait source images (large, not served; runtime uses /normalized/)
/public/market-source-portraits/*.jpg
/public/market-source-portraits/*.jpeg
/public/market-source-portraits/*.png
/public/market-source-portraits/*.webp

# Rejected normalized portraits (excluded from manifest quarantine)
/public/market-source-portraits/normalized/nba-03.webp
/public/market-source-portraits/normalized/multi-02.webp
# NOTE: manifest.json and accepted normalized/*.webp are committed (tracked)
#       and remain tracked despite ignore rules above.
